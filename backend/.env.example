APP_NAME=AI Closer
APP_ENV=development
DEBUG=true

# SQLite for local development. Use a PostgreSQL URL in production:
# postgresql+psycopg://user:password@localhost:5432/ai_closer
DATABASE_URL=sqlite:///./ai_closer.db

CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,null

# Supported values: ollama, groq, mock
LLM_PROVIDER=ollama

# Ollama Llama 3.1 8B model name:
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# Groq users can set:
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

LLM_TEMPERATURE=0.2
# Timeout for LLM requests in seconds. Set to 0 to disable timeout completely.
LLM_TIMEOUT_SECONDS=600

# Helpful for demos when Ollama/Groq is not running. Set false in production.
FALLBACK_TO_MOCK_ON_LLM_ERROR=true
MAX_TRANSCRIPT_CHUNK_CHARS=12000
MAX_PROMPT_CHARS=18000

# Path to services/pricing JSON (relative to backend/ or absolute)
SERVICES_CATALOG_PATH=data/services.json

